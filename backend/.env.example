# Example environment variables for `Barnaktiv.API` / `Barnaktiv.Worker`.
# Copy values to your host secret store or local environment.
# .NET does not load `.env.example` automatically.

# API
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
ConnectionStrings__DefaultConnection=Server=tcp:sql-server.database.windows.net,1433;Initial Catalog=BarnaktivDb;User ID=your-user;Password=your-password;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
AdminApiKey__HeaderName=X-Barnaktiv-Admin-Key
AdminApiKey__ApiKey=replace-with-a-long-random-secret
Cors__AllowedOrigins__0=https://frontend-domain.com

# AI
# Keep `Ai__Enabled=false` until `Ai__ApiKey` is configured.
Ai__Enabled=false
Ai__Provider=OpenAI
Ai__ApiKey=replace-with-openai-or-azure-openai-key
Ai__Endpoint=
Ai__ChatModel=gpt-4o-mini
Ai__EmbeddingModel=text-embedding-3-small
Ai__MaxRequestsPerMinute=10
Ai__MaxQuestionLength=500

# Worker
DOTNET_ENVIRONMENT=Production
Ingestion__Automation__Enabled=true
Ingestion__Automation__RunOnStartup=true
Ingestion__Automation__StartupDelay=00:00:30
Ingestion__Automation__Interval=01:00:00
